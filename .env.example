# Supabase 키 (Supabase 프로젝트 → Settings → API 에서 복사)
# 이 파일을 .env.local 로 복사해서 값 채우기. .env.local 은 git에 안 올라감.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# 시드 스크립트(stats.json 업로드)용 — service_role 키. 절대 프론트/깃에 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
# 시드 대상 사용자 이메일(가입한 본인)
SEED_USER_EMAIL=mlnyx104@gmail.com
